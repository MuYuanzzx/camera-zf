/*********************************************************************************************************************
* CYT4BB 逐飞总钻风 稳定亮斑中心检测
* 功能：有亮点→标记红色3×3中心；无亮点→中心固定在画面中间，无红色标记
* 核心：仅窗口求和+平均亮度判断，无多余运算（嵌入式最优）
********************************************************************************************************************/
#include "zf_common_headfile.h"
#include <stdint.h>

#define INCLUDE_BOUNDARY_TYPE   3
#define BOUNDARY_NUM            (MT9V03X_H * 2)

// 边界数组：仅用第2组（xy_x2/y2）显示红色中心
uint8 xy_x1_boundary[BOUNDARY_NUM], xy_x2_boundary[BOUNDARY_NUM], xy_x3_boundary[BOUNDARY_NUM];
uint8 xy_y1_boundary[BOUNDARY_NUM], xy_y2_boundary[BOUNDARY_NUM], xy_y3_boundary[BOUNDARY_NUM];

uint8 x1_boundary[MT9V03X_H], x2_boundary[MT9V03X_H], x3_boundary[MT9V03X_H];
uint8 y1_boundary[MT9V03X_W], y2_boundary[MT9V03X_W], y3_boundary[MT9V03X_W];

uint8 image_copy[MT9V03X_H][MT9V03X_W];
#define LED1                    P19_0

// 核心参数（可根据实际场景微调）
#define WINDOW_SIZE     3       // 5×5窗口找亮区（无需改）
#define BRIGHT_THRESH   40      // 亮度差阈值：最亮窗口-平均亮度>80才判定有亮点
#define ROI_SIZE       41      // 局部ROI大小（围绕初始中心）
#define AREA_THRESH    10      // 最小有效亮斑面积（过滤噪点）
#define THRESH_RATIO   8       // 自适应阈值比例（0.8 → 整数运算：×8÷10）


// +++ 新增：信标丢失判定阈值（连续3帧未识别则判定丢失）
#define LOST_FRAME_THRESH 3
// 3. 滑动平均滤波缓冲区（适配小分辨率，滤波更重要）
#define FILTER_LEN 5
int16_t PX_buf[FILTER_LEN] = {0};
int16_t PY_buf[FILTER_LEN] = {0};
uint8_t buf_idx = 0;

// 全局：是否识别到有效信标
uint8_t is_beacon_detected = 0;
// +++ 新增：未识别帧数计数器（信标丢失判定用）
uint8_t lost_frame_cnt = 0;

// 2. 适配188×120的控制参数（重点！）
#define K_ROT     0.1f      // 旋转比例系数（适配小分辨率，增大）
#define K_FWD     1.0f     // 前进比例系数（适配小分辨率，增大）
#define K_TRANS   0.125f     // 横向平移系数（新手先设0）
#define PX_DEAD1   30         // PX死区(快速旋转对准)
#define PX_DEAD2   4        // PX死区(对准)
// #define PX_DEAD3   4        // PX死区（缩小，适配小分辨率）
#define PY_DEAD   10         // PY死区（缩小，适配小分辨率）
#define VW_MAX    80        // 最大旋转速度（降低，避免过冲）
#define VX_MAX    150        // 最大前进速度（降低）
#define VY_MAX    20        // 最大横向平移速度（降低）
#define SEARCH_VW 70        // 搜索旋转速度（降低）

// 全局：亮斑中心（默认画面中心）
int16 bright_center_x = MT9V03X_W / 2;
int16 bright_center_y = MT9V03X_H / 2;

//全局，原点坐标中心
int16 CenterX = MT9V03X_W / 2;
int16 CenterY = MT9V03X_H;

int16 PX = 0;
int16 PY = 0;

// +++ 新增：追信标状态机枚举（方便后续扩展）
typedef enum {
    BEACON_STATE_LOST,          // 信标丢失：旋转搜索
    BEACON_STATE_ALIGNING,      // 找到信标但未对准：仅旋转对准，关闭平移/前进
    BEACON_STATE_TRACKING,      // 已对准：仅平移+前进，关闭旋转
    // 后续可扩展：BEACON_STATE_APPROACH（逼近减速）、BEACON_STATE_STOP（停止）等
} BeaconState;

static BeaconState current_state = BEACON_STATE_LOST;

//串口发送
uint8_t RxPacket[6];            
int16_t SpeedPacket[3];

void SpeedPacket_to_RxPacket(void) {
    // 步骤1：将volatile的int16_t数组读取到普通数组（保证数据完整性）
    int16_t speed_buf[3];
    for (int i = 0; i < 3; i++) {
        speed_buf[i] = SpeedPacket[i];
    }

    // 步骤2：小端模式拆分每个int16_t为2个uint8_t（核心逻辑）
    // 低8位：& 0xFF 提取低8位（屏蔽高8位）
    // 高8位：>> 8 右移8位后 & 0xFF（避免符号位扩展影响）
    // SpeedPacket[0] 拆分
    RxPacket[0] = (uint8_t)(speed_buf[0] & 0xFF);        // 低8位 → RxPacket[0]
    RxPacket[1] = (uint8_t)((speed_buf[0] >> 8) & 0xFF); // 高8位 → RxPacket[1]
    
    // SpeedPacket[1] 拆分
    RxPacket[2] = (uint8_t)(speed_buf[1] & 0xFF);        // 低8位 → RxPacket[2]
    RxPacket[3] = (uint8_t)((speed_buf[1] >> 8) & 0xFF); // 高8位 → RxPacket[3]
    
    // SpeedPacket[2] 拆分
    RxPacket[4] = (uint8_t)(speed_buf[2] & 0xFF);        // 低8位 → RxPacket[4]
    RxPacket[5] = (uint8_t)((speed_buf[2] >> 8) & 0xFF); // 高8位 → RxPacket[5]
}

void SetCarSpeed(int16_t vx, int16_t vy, int16_t vw)//串口发送函数
{
    SpeedPacket[0] = vx; 
    SpeedPacket[1] = vy; 
    SpeedPacket[2] = vw; 
    SpeedPacket_to_RxPacket();
    uart_write_byte(UART_0, 0xAB);
    uart_write_buffer(UART_0, RxPacket, 6);
    uart_write_byte(UART_0, 0xBA);
}

// 4. 滤波函数（小分辨率下识别抖动更明显，必须加）
void FilterPXPY() {
    // 存入缓冲区
    PX_buf[buf_idx] = PX;
    PY_buf[buf_idx] = PY;
    buf_idx = (buf_idx + 1) % FILTER_LEN;
    // 计算平均值（减少单帧抖动）
    int32_t px_sum = 0, py_sum = 0;
    for (int i = 0; i < FILTER_LEN; i++) {
        px_sum += PX_buf[i];
        py_sum += PY_buf[i];
    }
    PX = px_sum / FILTER_LEN;
    PY = py_sum / FILTER_LEN;
}

// +++ 新增：信标丢失判定函数（最小化新增）
void CheckBeaconLost() {
    lost_frame_cnt++;
    if (lost_frame_cnt >= LOST_FRAME_THRESH) {
        bright_center_x = MT9V03X_W / 2;
        bright_center_y = MT9V03X_H / 2;
        PX = 0;
        PY = 0;
        is_beacon_detected = 0;
        lost_frame_cnt = LOST_FRAME_THRESH;
    }
}

// 7. 更新信标坐标（适配188×120）
void UpdateBeaconPos(int16_t x, int16_t y) {
    // 限制坐标在画面内（小分辨率易出界，加保护）
    // --- 替换IMG_W/IMG_H为MT9V03X_W/MT9V03X_H（原有代码用的是这个宏）
    if (x < 0) x = 0;
    if (x >= MT9V03X_W) x = MT9V03X_W - 1;
    if (y < 0) y = 0;
    if (y >= MT9V03X_H) y = MT9V03X_H - 1;


    bright_center_x = x;
    bright_center_y = y;
    // 更新偏移量
    PY = -(bright_center_y - CenterY);
    PX = bright_center_x - CenterX+ 25*(120-PY)/120;
    
    // 标记信标有效 + 重置丢失计数器
    lost_frame_cnt = 0; // +++ 新增：重置丢失计数
    is_beacon_detected = 1;
}

// 5. 麦轮车追信标核心控制函数（适配188×120）
void TrackBeacon() {
    int16_t vx = 0, vy = 0, vw = 0;

    // ========== 第一步：状态切换逻辑（核心，新增对准状态切换） ==========

    switch(current_state)
    {
        case BEACON_STATE_LOST:
            if (!is_beacon_detected)
            {
                // 信标丢失 → 切换到“丢失搜索”状态
                current_state = BEACON_STATE_LOST;
            }
            if (is_beacon_detected)
            {
                //找到信标但未对准 → 切换到“对准”状态
                if (abs(PX) > PX_DEAD2)
                {
                    current_state = BEACON_STATE_ALIGNING;
                }
                else
                {
                    //已对准（PX≤PX_DEAD）→ 切换到“追踪”状态（开启平移+前进）
                    current_state = BEACON_STATE_TRACKING;
                }
            }
            break;
        
        case BEACON_STATE_ALIGNING:
            if (abs(PX) <= PX_DEAD2)
            {
                // 已对准（PX≤PX_DEAD）→ 切换到“追踪”状态（开启平移+前进）
                current_state = BEACON_STATE_TRACKING;
            }
            break;

        case BEACON_STATE_TRACKING:
            if (!is_beacon_detected)
            {
                // 信标丢失 → 切换到“丢失搜索”状态
                current_state = BEACON_STATE_LOST;
            }
            break;
    }
   

    // ========== 第二步：各状态行为逻辑（严格保留你指定的代码） ==========
    switch (current_state)
    {
        case BEACON_STATE_LOST:
            // 状态1：信标丢失 → 旋转搜索（保留你原有的旋转计算逻辑）
            vw = SEARCH_VW; // 死区内用默认搜索速度
            vx = 0;          // 禁止前进
            vy = 0;          // 禁止平移
            break;

        case BEACON_STATE_ALIGNING:
            // 状态2：找到信标但未对准 → 仅旋转对准，关闭平移/前进
            if (abs(PX) > PX_DEAD1)
            {
                if (PX > 0)
                {
                    vw = 35; // 严格保留此行
                }
                else
                {
                    vw = -35;
                }
            }
            else if (abs(PX) > PX_DEAD2)
            {
                if (PX > 0)
                {
                    vw = 15; // 严格保留此行
                }
                else
                {
                    vw = -15;
                }
            }
            else
            {
                vw = 0; // 对准后旋转停止
            }
            vx = 0; // 未对准前禁止前进
            vy = 0; // 未对准前禁止平移
            break;

        case BEACON_STATE_TRACKING:
            // 前进控制逻辑（严格保留你指定的代码）
            if (PY > PY_DEAD){
                vx = 145;
                // 未对准时减速（严格保留此行）
                if (abs(PX) > PX_DEAD2)
                {
                    vx = 100; // 严格保留此行
                }
                // 限幅
                if (vx > VX_MAX) vx = VX_MAX;
                if (vx < -VX_MAX) vx = -VX_MAX;
            } else {
                vx = 0;
            }

            // 横向平移控制逻辑（仅对准后开启）
            if (K_TRANS > 0 && abs(PX) > PX_DEAD2)
            {
                vy = K_TRANS*4 * PX;
                vw = K_TRANS*3 * PX;
                // 限幅
                if (vy > VY_MAX) vy = VY_MAX;
                if (vy < -VY_MAX) vy = VY_MAX;
                if (vw > VW_MAX) vw = VW_MAX;
                if (vw < -VW_MAX) vw = VW_MAX;
            } else {
                vy = 0;
                vw = 0;
            }
            break;

        default:
            // 默认状态：丢失搜索（容错）
            current_state = BEACON_STATE_LOST;
            vw = SEARCH_VW;
            vx = 0;
            vy = 0;
            break;
    }

    // ========== 第三步：执行控制指令（所有状态共用） ==========
    SetCarSpeed(vx, vy, vw);
}


// 【内部辅助函数】8连通域分析（嵌入式适配，不对外暴露）
static void find_max_connected(int16 roi_x0, int16 roi_y0, int16 roi_x1, int16 roi_y1, uint8 thresh,
                               int16 *final_x, int16 *final_y)
{
    uint8 visited[ROI_SIZE][ROI_SIZE] = {0}; // 访问标记
    int16 stack_x[ROI_SIZE*ROI_SIZE] = {0};  // 栈替代递归
    int16 stack_y[ROI_SIZE*ROI_SIZE] = {0};
    int8 dx[8] = {-1,0,1,-1,1,-1,0,1};       // 8连通方向
    int8 dy[8] = {-1,-1,-1,0,0,1,1,1};
    
    uint32 max_area = 0;
    int64 sum_x = 0, sum_y = 0, sum_i = 0;   // 防溢出
    
    // 遍历ROI内所有像素
    for (int16 y_roi = 0; y_roi <= roi_y1 - roi_y0; y_roi++)
    {
        for (int16 x_roi = 0; x_roi <= roi_x1 - roi_x0; x_roi++)
        {
            int16 x = roi_x0 + x_roi;
            int16 y = roi_y0 + y_roi;
            
            if (visited[y_roi][x_roi] == 0 && image_copy[y][x] > thresh)
            {
                // 初始化当前连通域
                int16 top = 0;
                stack_x[top] = x_roi;
                stack_y[top] = y_roi;
                top++;
                visited[y_roi][x_roi] = 1;
                
                uint32 curr_area = 0;
                int64 curr_sum_x = 0, curr_sum_y = 0, curr_sum_i = 0;
                
                // 栈遍历连通域
                while (top > 0)
                {
                    top--;
                    int16 cx_roi = stack_x[top];
                    int16 cy_roi = stack_y[top];
                    int16 cx = roi_x0 + cx_roi;
                    int16 cy = roi_y0 + cy_roi;
                    uint8 pix = image_copy[cy][cx];
                    
                    // 累计质心参数
                    curr_area++;
                    curr_sum_x += (int64)cx * pix;
                    curr_sum_y += (int64)cy * pix;
                    curr_sum_i += pix;
                    
                    // 遍历8邻域
                    for (int8 k = 0; k < 8; k++)
                    {
                        int16 nx_roi = cx_roi + dx[k];
                        int16 ny_roi = cy_roi + dy[k];
                        int16 nx = roi_x0 + nx_roi;
                        int16 ny = roi_y0 + ny_roi;
                        
                        if (nx_roi >=0 && nx_roi <= roi_x1 - roi_x0 &&
                            ny_roi >=0 && ny_roi <= roi_y1 - roi_y0 &&
                            visited[ny_roi][nx_roi] == 0 &&
                            image_copy[ny][nx] > thresh)
                        {
                            visited[ny_roi][nx_roi] = 1;
                            stack_x[top] = nx_roi;
                            stack_y[top] = ny_roi;
                            top++;
                        }
                    }
                }
                
                // 更新最大连通域
                if (curr_area > max_area && curr_area > AREA_THRESH)
                {
                    max_area = curr_area;
                    sum_x = curr_sum_x;
                    sum_y = curr_sum_y;
                    sum_i = curr_sum_i;
                }
            }
        }
    }
    
    // 计算质心（整数运算，保留精度）
    if (sum_i > 0)
    {
        *final_x = (int16)(sum_x / sum_i);  // 直接取整，嵌入式适配
        *final_y = (int16)(sum_y / sum_i);
    }
}

// 【核心函数】和你原有函数名/接口完全一致，直接替换即可
void find_bright_center(void)
{
    int16 half_win = WINDOW_SIZE / 2;
    uint32 max_win_sum = 0;     // 最亮窗口的像素和
    uint32 total_sum = 0;       // 图像总像素和（算平均用）
    int16 temp_x = MT9V03X_W / 2;
    int16 temp_y = MT9V03X_H / 2;

    // 第一步：计算图像整体总亮度（顺便找最亮窗口）→ 完全保留原有逻辑
    for (int16 y = 0; y < MT9V03X_H; y++)
    {
        for (int16 x = 0; x < MT9V03X_W; x++)
        {
            total_sum += image_copy[y][x]; // 累计总亮度

            // 只在能放下5×5窗口的区域找最亮窗口
            if (y >= half_win && y < MT9V03X_H - half_win &&
                x >= half_win && x < MT9V03X_W - half_win)
            {
                uint32 win_sum = 0;
                // 5×5窗口求和（比算平均快，结果等价）
                for (int8 dy = -half_win; dy <= half_win; dy++)
                {
                    for (int8 dx = -half_win; dx <= half_win; dx++)
                    {
                        win_sum += image_copy[y + dy][x + dx];
                    }
                }
                // 更新最亮窗口位置
                if (win_sum > max_win_sum)
                {
                    max_win_sum = win_sum;
                    temp_x = x;
                    temp_y = y;
                }
            }
        }
    }

    // 第二步：计算平均亮度 + 判断是否有有效亮点 → 完全保留原有逻辑
    uint32 avg_bright = total_sum / (MT9V03X_W * MT9V03X_H); // 图像平均亮度
    uint32 avg_win_bright = max_win_sum / (WINDOW_SIZE * WINDOW_SIZE); // 最亮窗口平均亮度
    uint32 bright_diff = avg_win_bright - avg_bright; // 最亮窗口 vs 整体平均的亮度差

    // 关键判断：亮度差超过阈值→有亮点；否则→无亮点（固定中心）
    if (bright_diff > BRIGHT_THRESH)
    {
        // ========== 新增精准识别逻辑（不影响外部接口） ==========
        int16 roi_half = ROI_SIZE / 2;
        // 计算ROI范围（边界保护）
        int16 roi_x0 = temp_x - roi_half;
        int16 roi_y0 = temp_y - roi_half;
        int16 roi_x1 = temp_x + roi_half;
        int16 roi_y1 = temp_y + roi_half;
        
        // 边界修正（适配单片机数组0起始）
        roi_x0 = (roi_x0 < 0) ? 0 : roi_x0;
        roi_y0 = (roi_y0 < 0) ? 0 : roi_y0;
        roi_x1 = (roi_x1 >= MT9V03X_W) ? (MT9V03X_W - 1) : roi_x1;
        roi_y1 = (roi_y1 >= MT9V03X_H) ? (MT9V03X_H - 1) : roi_y1;
        
        // 自适应阈值（中心亮度×0.8）
        uint8 center_pix = image_copy[temp_y][temp_x];
        uint8 roi_thresh = (center_pix * THRESH_RATIO) / 10;
        
        // 找最大连通域并计算质心
        find_max_connected(roi_x0, roi_y0, roi_x1, roi_y1, roi_thresh, &temp_x, &temp_y);
        // ========== 新增逻辑结束 ==========
        
        // 原有逻辑完全保留（接口不变）
        bright_center_x = temp_x;
        bright_center_y = temp_y;
        UpdateBeaconPos(temp_x, temp_y); // 你的原有函数，调用参数不变
        
        // 填充红色3×3中心到边界数组 → 完全保留原有逻辑
        int16 cnt = 0;
        for (int8 dy = -1; dy <= 1 && cnt < BOUNDARY_NUM; dy++)
        {
            for (int8 dx = -1; dx <= 1 && cnt < BOUNDARY_NUM; dx++)
            {
                int16 x = bright_center_x + dx;
                int16 y = bright_center_y + dy;
                if (x >= 0 && x < MT9V03X_W && y >= 0 && y < MT9V03X_H)
                {
                    xy_x2_boundary[cnt] = x;
                    xy_y2_boundary[cnt] = y;
                    cnt++;
                }
            }
        }
    }
    else
    {
        // 无亮点逻辑 → 完全保留原有代码，无任何修改
        bright_center_x = MT9V03X_W / 2;
        bright_center_y = MT9V03X_H / 2;
        CheckBeaconLost(); // 你的原有函数
        
        // 填充红色3×3中心到边界数组
        int16 cnt = 0;
        for (int8 dy = -1; dy <= 1 && cnt < BOUNDARY_NUM; dy++)
        {
            for (int8 dx = -1; dx <= 1 && cnt < BOUNDARY_NUM; dx++)
            {
                int16 x = bright_center_x + dx;
                int16 y = bright_center_y + dy;
                if (x >= 0 && x < MT9V03X_W && y >= 0 && y < MT9V03X_H)
                {
                    xy_x2_boundary[cnt] = x;
                    xy_y2_boundary[cnt] = y;
                    cnt++;
                }
            }
        }
    }
}

